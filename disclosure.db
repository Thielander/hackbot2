# Git / Version Control — HIGH
# -----------------------------------------------------------------------
/.git/config!git!HIGH!Git config - may reveal remote URLs and credentials
/.git/HEAD!git!HIGH!Git HEAD pointer - confirms .git exposure
/.git/COMMIT_EDITMSG!git!HIGH!Last commit message
/.gitignore!git!MEDIUM!Git ignore rules - reveals file structure
/.gitmodules!git!MEDIUM!Git submodule config
/.gitattributes!git!LOW!Git attributes
/.svn/entries!git!HIGH!SVN repository metadata
